{
  "name": "@agent24/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "GENERATED types for the Agent24 v1 protocol — do not edit src/ by hand; run `pnpm gen:api` at repo root",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "gen": "openapi-typescript ../../protocol/openapi.yaml -o src/openapi.d.ts && json2ts -i ../../protocol/events.schema.json -o src/events.d.ts --cwd ../../protocol",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "openapi-typescript": "^7.9.1",
    "typescript": "^5.6.0"
  }
}