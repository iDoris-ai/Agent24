{
  "$id": "https://github.com/iDoris-ai/Agent24/protocol/events.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent24 v1 WebSocket Event Protocol",
  "description": "GENERATED from the agent24-protocol Rust crate (task B4) — do not edit by hand; regenerate with `cargo run -p agent24-protocol --bin export-schema`. Wire contract details: docs/specs/SPEC-002-protocol.md §3 (message classes: approval.required is the only REQUEST-class event, answered via POST /api/v1/approvals/{id}; everything else is NOTIFICATION). Conventions: snake_case; ULID ids; ISO 8601 UTC ts; nullable fields always present as null; per-connection monotonic seq; clients ignore unknown types/fields.",
  "type": "object",
  "properties": {
    "seq": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "v": {
      "description": "Protocol major version — always 1",
      "const": 1
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/RunStartedPayload"
        },
        "type": {
          "type": "string",
          "const": "run.started"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ModelDeltaPayload"
        },
        "type": {
          "type": "string",
          "const": "model.delta"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/RunCompletedPayload"
        },
        "type": {
          "type": "string",
          "const": "run.completed"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/RunFailedPayload"
        },
        "type": {
          "type": "string",
          "const": "run.failed"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/RunCancelledPayload"
        },
        "type": {
          "type": "string",
          "const": "run.cancelled"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ToolStartedPayload"
        },
        "type": {
          "type": "string",
          "const": "tool.started"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ToolCompletedPayload"
        },
        "type": {
          "type": "string",
          "const": "tool.completed"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "description": "REQUEST class: the client MUST answer via POST /api/v1/approvals/{id}.\nFail-closed: no answer before `expires_at` resolves to timed_out.",
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/Approval"
        },
        "type": {
          "type": "string",
          "const": "approval.required"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ApprovalResolvedPayload"
        },
        "type": {
          "type": "string",
          "const": "approval.resolved"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ScheduleFiredPayload"
        },
        "type": {
          "type": "string",
          "const": "schedule.fired"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    },
    {
      "type": "object",
      "properties": {
        "payload": {
          "$ref": "#/$defs/ScheduleDisabledPayload"
        },
        "type": {
          "type": "string",
          "const": "schedule.disabled"
        }
      },
      "required": [
        "type",
        "payload"
      ]
    }
  ],
  "required": [
    "v",
    "seq",
    "ts"
  ],
  "$defs": {
    "Approval": {
      "type": "object",
      "properties": {
        "available_decisions": {
          "description": "Server-driven open set — UIs render exactly this list",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "decided_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "decision": {
          "description": "Set once resolved",
          "anyOf": [
            {
              "$ref": "#/$defs/Decision"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "description": "After this instant the approval resolves to timed_out",
          "type": "string",
          "format": "date-time"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "description": "Open enum: exec | fs_write | network | module",
          "type": "string"
        },
        "payload": {
          "description": "Kind-specific detail (e.g. command argv, cwd, reason)",
          "type": "object",
          "additionalProperties": true
        },
        "run_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ApprovalStatus"
        },
        "summary": {
          "type": "string"
        },
        "tool_call_id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "run_id",
        "tool_call_id",
        "kind",
        "summary",
        "payload",
        "available_decisions",
        "status",
        "expires_at",
        "created_at",
        "decision",
        "decided_at"
      ]
    },
    "ApprovalResolvedPayload": {
      "description": "Broadcast so every connected client converges",
      "type": "object",
      "properties": {
        "approval_id": {
          "type": "string"
        },
        "decision_type": {
          "description": "Open enum — the Decision.type that resolved it, or timed_out/aborted",
          "type": "string"
        },
        "run_id": {
          "type": "string"
        }
      },
      "required": [
        "approval_id",
        "run_id",
        "decision_type"
      ]
    },
    "ApprovalStatus": {
      "description": "timed_out is equivalent to a denial (fail-closed)",
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "denied",
        "aborted",
        "timed_out"
      ]
    },
    "Decision": {
      "description": "OPEN SET, server-driven: valid `type` values for a given approval are\nexactly its `available_decisions`. Known: approve, approve_for_session,\ndeny (reason required), abort. Future types may carry extra fields (kept\nin `extra` via flatten). Fail-closed: the implementation default (broken\nchannel, cancelled run, daemon restart) is equivalent to abort/deny.",
      "type": "object",
      "properties": {
        "reason": {
          "description": "Required when kind == \"deny\"",
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "required": [
        "type"
      ]
    },
    "ErrorBody": {
      "type": "object",
      "properties": {
        "code": {
          "description": "Open enum: invalid_request, unauthorized, not_found, conflict,\napproval_already_resolved, provider_unavailable,\nrun_not_cancellable (reserved), payload_too_large, internal",
          "type": "string"
        },
        "details": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "ModelDeltaPayload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string"
        },
        "text": {
          "description": "Streaming text increment",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "text"
      ]
    },
    "RunCancelledPayload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string"
        }
      },
      "required": [
        "run_id"
      ]
    },
    "RunCompletedPayload": {
      "type": "object",
      "properties": {
        "output": {
          "$ref": "#/$defs/RunOutputPayload"
        },
        "run_id": {
          "type": "string"
        },
        "usage": {
          "$ref": "#/$defs/Usage"
        }
      },
      "required": [
        "run_id",
        "output",
        "usage"
      ]
    },
    "RunFailedPayload": {
      "type": "object",
      "properties": {
        "error": {
          "$ref": "#/$defs/ErrorBody"
        },
        "run_id": {
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "error"
      ]
    },
    "RunOutputPayload": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text"
      ]
    },
    "RunStartedPayload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string"
        },
        "schedule_id": {
          "description": "Set when fired by a schedule",
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "description": "Null for transient runs (e.g. /chat)",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "run_id",
        "session_id",
        "schedule_id"
      ]
    },
    "ScheduleDisabledPayload": {
      "type": "object",
      "properties": {
        "reason": {
          "description": "Open enum; currently only consecutive_failures",
          "type": "string"
        },
        "schedule_id": {
          "type": "string"
        }
      },
      "required": [
        "schedule_id",
        "reason"
      ]
    },
    "ScheduleFiredPayload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string"
        },
        "schedule_id": {
          "type": "string"
        }
      },
      "required": [
        "schedule_id",
        "run_id"
      ]
    },
    "ToolCompletedPayload": {
      "type": "object",
      "properties": {
        "output_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ToolCompletedStatus"
        },
        "tool_call_id": {
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "tool_call_id",
        "status",
        "output_summary"
      ]
    },
    "ToolCompletedStatus": {
      "description": "Closed set per protocol/events.schema.json (a running tool never emits\ntool.completed)",
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "denied"
      ]
    },
    "ToolStartedPayload": {
      "type": "object",
      "properties": {
        "input_summary": {
          "description": "Summarized — full input is audit-only",
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "tool_call_id": {
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "tool_call_id",
        "tool",
        "input_summary"
      ]
    },
    "Usage": {
      "type": "object",
      "properties": {
        "completion_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "format": "double",
          "default": 0.0
        },
        "prompt_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "prompt_tokens",
        "completion_tokens",
        "total_tokens"
      ]
    }
  }
}
