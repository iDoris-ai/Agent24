{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": [
      "./apps/desktop/tsconfig.json",
      "./apps/desktop/tsconfig.electron.json",
      "./packages/node-daemon/tsconfig.eslint.json"
    ],
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "es2022": true,
    "node": true,
    "browser": true
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/explicit-module-boundary-types": "off"
  },
  "ignorePatterns": [
    "dist/",
    "release/",
    "vendor/",
    "*.config.ts",
    "*.config.js",
    "packages/contract-tests/"
  ]
}