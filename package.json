{
  "name": "agent24-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Agent24 — 24/7 personal & community agent platform (Electron shell + daemon + protocol)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @agent24/node-daemon build && pnpm --filter @agent24/desktop dev",
    "build": "pnpm --filter @agent24/node-daemon build && pnpm --filter @agent24/desktop build",
    "typecheck": "pnpm --filter @agent24/desktop typecheck && pnpm --filter @agent24/node-daemon typecheck",
    "test": "pnpm --filter @agent24/desktop test && pnpm --filter @agent24/node-daemon test",
    "test:contract": "pnpm --filter @agent24/contract-tests test",
    "lint": "eslint apps/desktop/src packages/node-daemon/src --ext .ts,.tsx",
    "format": "prettier --write \"apps/desktop/src/**/*.{ts,tsx,css}\" \"packages/node-daemon/src/**/*.ts\"",
    "build:mac": "pnpm --filter @agent24/desktop build:mac",
    "build:win": "pnpm --filter @agent24/desktop build:win",
    "build:linux": "pnpm --filter @agent24/desktop build:linux",
    "gen:api": "pnpm --filter @agent24/api-client gen"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
