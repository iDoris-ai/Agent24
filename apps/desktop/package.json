{
  "name": "@agent24/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Agent24 Electron desktop shell",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && pnpm build:rust:debug && pnpm --filter @agent24/node-daemon build && tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:rust:debug": "cargo build -p agent24d --manifest-path ../../rust/Cargo.toml",
    "build:rust": "cargo build --release -p agent24d -p agent24-cli --manifest-path ../../rust/Cargo.toml",
    "build:mac": "pnpm build:rust && pnpm --filter @agent24/node-daemon build && pnpm build && electron-builder --mac",
    "build:win": "pnpm build:rust && pnpm --filter @agent24/node-daemon build && pnpm build && electron-builder --win",
    "build:linux": "pnpm build:rust && pnpm --filter @agent24/node-daemon build && pnpm build && electron-builder --linux",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.electron.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent24/node-daemon": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "ai.auraai.agent24",
    "productName": "Agent24",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../packages/node-daemon/dist",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "extraResources": [
        {
          "from": "../../rust/target/release/agent24d",
          "to": "backend/agent24d"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "../../rust/target/release/agent24d.exe",
          "to": "backend/agent24d.exe"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "extraResources": [
        {
          "from": "../../rust/target/release/agent24d",
          "to": "backend/agent24d"
        }
      ]
    }
  }
}